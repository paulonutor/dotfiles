[user]
	name = Paul Onutor
	email = {{ .email }}

[core]
	editor = zed --wait

[init]
	defaultBranch = main

[fetch]
	prune = true

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[merge]
	ff = only

[rebase]
	autoStash = true
	autoSquash = true
	abbreviateCommands = true

[alias]
	amend = commit --amend --no-edit
	undo = reset --soft HEAD^
	wip = !git add --all && git commit -a -m "WIP"
	pushf = push --force-with-lease
	co = checkout
	cob = checkout -b
	cb = checkout -b
	cp = cherry-pick --ff
	st = status
	stat = status
	lg = log --pretty=format:'%C(auto)%h%d %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
	rb = rebase
	rbi = rebase --interactive

[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
